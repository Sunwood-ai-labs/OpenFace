      const tabs = container?.querySelector("overflow-menu.ui.tabular.menu");
      (tabs || repoButtonRow || container?.querySelector(".repo-header"))?.insertAdjacentElement("afterend", pathbar);
    }
    const commitTabs = document.querySelector(".page-content.repository.commits overflow-menu.ui.tabular.menu");
    const commitPathbar = document.querySelector(".openface-commit-pathbar");
    if (commitTabs && commitPathbar && commitTabs.nextElementSibling !== commitPathbar) {
      commitTabs.insertAdjacentElement("afterend", commitPathbar);
    }
    for (const header of document.querySelectorAll(".repository.commits .ui.header, .repository .ui.header")) {
      const text = header.textContent.trim();
      if (/^\d+\s+commits?$/.test(text)) {
        const commitTotal = text.match(/^\d+/)?.[0] || "";
        const filesHref = commitContext
          ? `/git/${commitContext.owner}/${commitContext.repo}/src/branch/${commitContext.branch}${commitContext.filePath ? `/${commitContext.filePath}` : ""}`
          : location.pathname.replace(/\/commits\/branch\//, "/src/branch/");
        header.innerHTML = `
