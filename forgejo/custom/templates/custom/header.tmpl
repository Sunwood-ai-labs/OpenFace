        item.setAttribute("href", "/git/openface/realtime-voice-space/src/branch/main/README.md");
        setText(item, "Docs");
        if (!item.querySelector(".openface-title-icon")) item.insertAdjacentHTML("afterbegin", navIcon.docs);
      }
      if (href.includes("/user/sign_up")) setText(item, "Sign Up");
      if (href.includes("/user/login")) setText(item, "Log In");
    }

    const login = document.querySelector('#navbar a[href*="/user/login"]');
    const signup = document.querySelector('#navbar a[href*="/user/sign_up"]');
    if (login && signup && signup.compareDocumentPosition(login) & Node.DOCUMENT_POSITION_FOLLOWING) {
      signup.parentElement?.insertBefore(login, signup);
    }

    const repoMatchRaw = location.pathname.match(/^\/git\/([^/]+)\/([^/]+)/);
    const repoMatch = repoMatchRaw && !["user", "repo", "org", "admin", "explore", "assets", "api"].includes(repoMatchRaw[1]) ? repoMatchRaw : null;
    const repoMenu = document.querySelector("overflow-menu.ui.tabular.menu .overflow-menu-items");
    if (repoMatch && repoMenu) {
      const [, owner, repo] = repoMatch;
      const repoItems = Array.from(repoMenu.querySelectorAll("a.item"));
      for (const item of repoItems) {
        const href = item.getAttribute("href") || "";
        if (href === `/git/${owner}/${repo}` || href.includes(`/src/`)) {
          setText(item, "Files");
          item.href = `/git/${owner}/${repo}/src/branch/main`;
          item.classList.add("openface-files-tab");
          item.classList.remove("openface-hide-tab");
          item.style.removeProperty("display");
        } else if (href.includes(`/issues`)) {
          setText(item, "Community");
          item.classList.add("openface-community-tab");
          item.classList.remove("openface-hide-tab");
          item.style.removeProperty("display");
        } else {
          item.classList.add("openface-hide-tab");
          item.style.setProperty("display", "none", "important");
          item.remove();
        }
      }

      const ensureRepoTab = (className, label, href, before) => {
        let tab = repoMenu.querySelector(`.${className}`);
        if (!tab) {
          tab = document.createElement("a");
          tab.className = `item ${className}`;
          repoMenu.insertBefore(tab, before || null);
        }
        tab.href = href;
        tab.textContent = label;
        tab.classList.remove("openface-hide-tab");
        tab.style.removeProperty("display");
        return tab;
      };

      const currentKindLabel = repoKindLabel();
      const currentKind = repoKindClass(currentKindLabel);
      const appLabel = currentKind === "model" ? "Model card" : currentKind === "dataset" ? "Dataset card" : "App";
      const appHref = `/${owner}/${repo}`;

      const communityTab = repoMenu.querySelector(".openface-community-tab") ||
        ensureRepoTab("openface-community-tab", "Community", `/git/${owner}/${repo}/issues`, null);
      const appTab = ensureRepoTab("openface-app-tab", appLabel, appHref, repoMenu.firstElementChild);
      const filesTab = ensureRepoTab("openface-files-tab", "Files", `/git/${owner}/${repo}/src/branch/main`, communityTab || appTab.nextSibling);
      if (communityTab && filesTab.nextSibling !== communityTab) {
        repoMenu.insertBefore(filesTab, communityTab);
      }
      const isRepoRoot = location.pathname === `/git/${owner}/${repo}` || location.pathname === `/git/${owner}/${repo}/`;
      const isRepoFilesSurface = new RegExp(`^/git/${owner.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}/${repo.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}/(?:src|blame|raw|find|search|commits|commit|compare|activity|graph|releases|tags|branches)(?:/|$)`).test(location.pathname);
      const isRepoCommunitySurface = new RegExp(`^/git/${owner.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}/${repo.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}/(?:issues|pulls|labels|milestones)(?:/|$)`).test(location.pathname);
      appTab.classList.toggle("active", isRepoRoot);
      filesTab.classList.toggle("active", !isRepoRoot && isRepoFilesSurface);
      communityTab.classList.toggle("active", !isRepoRoot && isRepoCommunitySurface);
      if (document.documentElement.getAttribute("data-openface-theme") === "cyberpunk") {
        for (const tab of [appTab, filesTab, communityTab]) {
          tab.style.setProperty("color", tab.classList.contains("active") ? "#f9a8d4" : "#cbd5e1", "important");
        }
      }
    }

    if (repoMatch && !document.querySelector(".openface-mobile-repo-tabs")) {
      const [, owner, repo] = repoMatch;
      const header = document.querySelector(".repo-header");
      const currentKindLabel = repoKindLabel();
      const currentKind = repoKindClass(currentKindLabel);
      const appLabel = currentKind === "model" ? "Model card" : currentKind === "dataset" ? "Dataset card" : "App";
      const isRepoRoot = location.pathname === `/git/${owner}/${repo}` || location.pathname === `/git/${owner}/${repo}/`;
      const isFiles = new RegExp(`^/git/${owner.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}/${repo.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}/(?:src|blame|raw|find|search|commits|commit|compare|activity|graph|releases|tags|branches)(?:/|$)`).test(location.pathname);
      const isCommunity = new RegExp(`^/git/${owner.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}/${repo.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}/(?:issues|pulls|labels|milestones)(?:/|$)`).test(location.pathname);
      if (header) {
        const tabs = document.createElement("nav");
        tabs.className = "openface-mobile-repo-tabs";
        tabs.setAttribute("aria-label", "Repository sections");
        tabs.innerHTML = `
          <a class="openface-app-tab ${isRepoRoot ? "active" : ""}" href="/${encodeURIComponent(owner)}/${encodeURIComponent(repo)}">${escapeHtml(appLabel)}</a>
          <a class="${isFiles ? "active" : ""}" href="/git/${encodeURIComponent(owner)}/${encodeURIComponent(repo)}/src/branch/main">Files</a>
          <a class="${isCommunity ? "active" : ""}" href="/git/${encodeURIComponent(owner)}/${encodeURIComponent(repo)}/issues">Community</a>
        `;
        header.insertAdjacentElement("afterend", tabs);
      }
    }

    const title = document.querySelector(".repo-header .flex-item-title");
    if (title && repoMatch && !title.querySelector(".openface-repo-kind")) {
      const kind = document.createElement("span");
      kind.className = "openface-repo-kind";
      const label = repoKindLabel();
      kind.textContent = label;
      title.closest(".repo-header")?.setAttribute("data-openface-kind", repoKindClass(label));
      title.insertBefore(kind, title.firstChild);
      updateRepoKindFromApi(repoMatch[1], repoMatch[2]);
    }

    enhanceDashboardPage();
    enhanceRepoUtilityPage();
    normalizeRepoControls();
    setTimeout(normalizeRepoControls, 250);
    setTimeout(normalizeRepoControls, 1000);
    let scheduled = false;
    const observer = new MutationObserver(() => {
      if (scheduled) return;
      scheduled = true;
      requestAnimationFrame(() => {
        scheduled = false;
        enhanceRepoUtilityPage();
        normalizeRepoControls();
      });
    });
    observer.observe(document.body, { childList: true, subtree: true, characterData: true });
    setInterval(normalizeRepoControls, 2000);
  });
})();
</script>
