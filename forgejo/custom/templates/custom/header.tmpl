      const data = await openfaceJson(`/git/api/v1/repos/${encodeURIComponent(ctx.owner)}/${encodeURIComponent(ctx.repo)}/contents${apiPath}?ref=${encodeURIComponent(ctx.branch)}`);
      if (!data) return;
