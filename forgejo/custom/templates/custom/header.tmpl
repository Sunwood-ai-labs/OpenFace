        badge.innerHTML = `${commentIcon}<span>${commentCount}</span>`;
        item.appendChild(badge);
      }
    }
    if (document.title.startsWith("イシュー")) {
      document.title = document.title.replace(/^イシュー/, "Community");
    }
  };

  const normalizeDocumentTitle = () => {
    const repoMatch = location.pathname.match(/^\/git\/([^/]+)\/([^/]+)/);
    const repoName = repoMatch ? `${decodeURIComponent(repoMatch[1])}/${decodeURIComponent(repoMatch[2])}` : "OpenFace";
    if (location.pathname.includes("/issues") || location.pathname.includes("/pulls")) {
      document.title = `Community - ${repoName} - OpenFace`;
      return;
    }
    if (location.pathname.includes("/commits/")) {
      document.title = `Commits - ${repoName} - OpenFace`;
      return;
    }
    if (location.pathname === "/git/user/sign_up") {
      document.title = "Sign Up - OpenFace";
      return;
    }
    if (location.pathname === "/git/user/login") {
      document.title = "Sign in - OpenFace";
      return;
    }
    if (location.pathname.includes("/src/branch/")) {
      document.title = document.title.replace(/\s+-\s+Forgejo:.*$/, " - OpenFace");
      return;
    }
    document.title = document.title.replace(/Forgejo: Beyond coding\. We forge\./g, "OpenFace");
  };

