          const label = isContributeResume ? "Resume contribution" : "Resume repository creation";
          const iconPath = isContributeResume
            ? "M96 32C43 32 0 75 0 128l0 224c0 53 43 96 96 96l320 0c53 0 96-43 96-96l0-224c0-53-43-96-96-96L96 32zM256 128c13.3 0 24 10.7 24 24l0 64 64 0c13.3 0 24 10.7 24 24s-10.7 24-24 24l-64 0 0 64c0 13.3-10.7 24-24 24s-24-10.7-24-24l0-64-64 0c-13.3 0-24-10.7-24-24s10.7-24 24-24l64 0 0-64c0-13.3 10.7-24 24-24z"
