  const updateRepoKindFromApi = async (owner, repo) => {
    const kind = document.querySelector(".repo-header .flex-item-title .openface-repo-kind");
    if (!kind) return;
    try {
      const response = await fetch(`/git/api/v1/repos/${encodeURIComponent(owner)}/${encodeURIComponent(repo)}/topics`, {
        credentials: "same-origin",
      });
      if (!response.ok) return;
      const data = await response.json();
      const topics = Array.isArray(data?.topics) ? data.topics : [];
      const label = labelFromTopics(topics);
      const kindClass = repoKindClass(label);
      kind.textContent = label;
      kind.closest(".repo-header")?.setAttribute("data-openface-kind", kindClass);
      const appLabel = kindClass === "model" ? "Model card" : kindClass === "dataset" ? "Dataset card" : "App";
      for (const appTab of document.querySelectorAll(".openface-app-tab")) {
        appTab.textContent = appLabel;
      }
      normalizeRepoControls();
    } catch {
      // Keep the DOM-derived fallback.
    }
  };

  const enhanceFileEditorPage = () => {
    if (!document.body.matches("[data-openface-file-editor]")) return;
    const form = document.querySelector(".repository.file.editor form.ui.edit.form, .repository.file.editor.upload form.ui.form");
    if (!form) return;

    const mode = document.body.getAttribute("data-openface-file-editor-mode") || "edit";
    const titleText = mode === "new" ? "Create a new file" : mode === "upload" ? "Upload files" : mode === "delete" ? "Delete file" : "Edit file";
    if (!form.querySelector(".openface-editor-title")) {
      const title = document.createElement("div");
      title.className = "openface-editor-title";
      title.innerHTML = `
        <span class="openface-editor-title-icon">${fontAwesomeIcon("file-lines", 384, 512, "M64 0C28.7 0 0 28.7 0 64L0 448c0 35.3 28.7 64 64 64l256 0c35.3 0 64-28.7 64-64l0-293.5c0-17-6.7-33.3-18.7-45.3L274.7 18.7C262.7 6.7 246.5 0 229.5 0L64 0zm192 152l0-88 88 88-88 0zM112 256l160 0c8.8 0 16 7.2 16 16s-7.2 16-16 16l-160 0c-8.8 0-16-7.2-16-16s7.2-16 16-16zm0 64l160 0c8.8 0 16 7.2 16 16s-7.2 16-16 16l-160 0c-8.8 0-16-7.2-16-16s7.2-16 16-16zm0 64l96 0c8.8 0 16 7.2 16 16s-7.2 16-16 16l-96 0c-8.8 0-16-7.2-16-16s7.2-16 16-16z")}</span>
        <span>
          <strong>${escapeHtml(titleText)}</strong>
          <small>Commit directly to this OpenFace repository.</small>
        </span>
      `;
      const header = form.querySelector(".repo-editor-header");
      form.insertBefore(title, header || form.firstElementChild);
    }

    const activeTab = form.querySelector(".ui.tabular.menu .active.item");
    if (activeTab && mode === "new") setText(activeTab, "New file");
    if (activeTab && mode === "upload") setText(activeTab, "Upload files");

    const cancelWrap = Array.from(form.querySelectorAll(".repo-editor-header span"))
      .find((span) => span.textContent.replace(/\s+/g, " ").trim().startsWith("or ") && span.querySelector('a[href*="/src/branch/"]'));
    if (cancelWrap && cancelWrap.textContent.replace(/\s+/g, " ").trim().startsWith("or ")) {
      const cancel = cancelWrap.querySelector("a");
      if (cancel) {
        cancelWrap.textContent = "";
        cancel.classList.add("openface-editor-cancel");
        cancel.textContent = "Cancel";
        cancelWrap.appendChild(cancel);
      }
    }

    const editorHeight = window.innerWidth < 640 ? "300px" : "320px";
    for (const editor of form.querySelectorAll(".monaco-editor, .monaco-editor .overflow-guard, .monaco-scrollable-element.editor-scrollable")) {
      editor.style.setProperty("height", editorHeight, "important");
      editor.style.setProperty("max-height", editorHeight, "important");
    }

    const summary = form.querySelector('input[name="commit_summary"]');
    if (summary && !summary.getAttribute("placeholder")?.includes("Commit message")) {
      summary.setAttribute("placeholder", mode === "new" ? "Commit message: add file" : "Commit message");
    }
    const message = form.querySelector('textarea[name="commit_message"]');
    if (message) message.setAttribute("placeholder", "Add an optional extended description...");
  };

