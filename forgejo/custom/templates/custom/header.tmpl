      if (body && index) {
        const authorName = author?.textContent?.trim() || "openface-admin";
        const timeText = time?.textContent?.trim() || "just now";
        body.innerHTML = `<span class="openface-issue-meta">${issueNumber} opened ${timeText} by <a href="${author?.getAttribute("href") || "/git/openface-admin"}">${authorName}</a></span>`;
