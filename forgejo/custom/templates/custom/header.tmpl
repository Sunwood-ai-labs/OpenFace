  const enhanceCommunityIssues = () => {
    if (!location.pathname.match(/^\/git\/([^/]+)\/([^/]+)\/(issues|pulls)\/?$/)) return;
    const issueList = document.querySelector("#issue-list");
    if (!issueList) return;
    const list = issueList.querySelector(".flex-list") || issueList;
    if (list && list.dataset.openfaceSorted !== "true") {
      const rank = (item) => {
        const title = item.querySelector(".issue-title")?.textContent?.trim() || "";
        if (/Upload SamplePNGImage/i.test(title)) return 1;
        if (/locally with speech-to-speech/i.test(title)) return 2;
        if (/16 gb VRAM/i.test(title)) return 3;
        return 10;
      };
      Array.from(list.querySelectorAll(":scope > .flex-item, :scope > .flex-list > .flex-item"))
        .sort((a, b) => rank(a) - rank(b))
        .forEach((item) => list.appendChild(item));
      list.dataset.openfaceSorted = "true";
    }
    const items = Array.from(issueList.querySelectorAll(".flex-list > .flex-item"));
    const discussionIcon = fontAwesomeIcon("message", 512, 512, "M64 0C28.7 0 0 28.7 0 64v288c0 35.3 28.7 64 64 64h80v72c0 9.8 5.8 18.6 14.8 22.5s19.5 1.8 26.4-5.2L296 416h152c35.3 0 64-28.7 64-64V64c0-35.3-28.7-64-64-64H64z");
    const pullIcon = fontAwesomeIcon("code-pull-request", 384, 512, "M64 96a32 32 0 1 0 0-64 32 32 0 0 0 0 64zm32 50.7C151.3 161.6 192 212.1 192 272v64c0 26.5 21.5 48 48 48h24.6c10.2-27.9 36.9-48 68.4-48 40.3 0 73 32.7 73 73s-32.7 73-73 73c-31.5 0-58.2-20.1-68.4-48H240c-53 0-96-43-96-96v-64c0-33-20.1-61.4-48.7-73.5C85.2 225.2 60.9 240 32 240c-40.3 0-73-32.7-73-73s32.7-73 73-73c28.8 0 53.7 16.7 65.4 40.9L96 146.7zM64 192a32 32 0 1 0 0-64 32 32 0 0 0 0 64zm272 242a32 32 0 1 0 0-64 32 32 0 0 0 0 64z");
    const commentIcon = fontAwesomeIcon("comment", 512, 512, "M512 240c0 114.9-114.6 208-256 208-37.1 0-72.4-6.4-104.2-17.9-11.9 8.7-31.3 20.6-54.3 30.6-24.1 10.5-52.5 17.6-81.7 13.9-6.6-.8-12.2-5.2-14.5-11.4s-.7-13.3 4.1-17.9l0 0 .3-.3c.3-.3.8-.8 1.5-1.6 1.4-1.6 3.6-4.1 6.2-7.4 5.3-6.6 12.5-16.3 19.6-28.3 10.6-17.9 20.6-40 24.4-64.9C20.4 306.3 0 274.7 0 240 0 125.1 114.6 32 256 32s256 93.1 256 208z");
    for (const item of items) {
      if (item.dataset.openfaceIssueEnhanced === "true") continue;
