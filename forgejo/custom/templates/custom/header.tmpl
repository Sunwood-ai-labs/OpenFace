      const time = item.querySelector("relative-time");
      const body = item.querySelector(".flex-item-body");
      const icon = item.querySelector(".flex-item-icon");
      item.dataset.openfaceIssueEnhanced = "true";
      if (title) title.textContent = title.textContent.trim();
      const issueNumber = index?.textContent.trim() || "";
      const isPullLike = location.pathname.includes("/pulls");
      const nativeCommentLink = item.querySelector('a[href*="#comments"], .issue-comment-count a, .comments a');
      const commentCount = Number(nativeCommentLink?.textContent.match(/[0-9]+/)?.[0] || 0);
      if (icon) {
        icon.classList.toggle("openface-community-pr-icon", isPullLike);
