    const historyHref = `/git/${encodeURIComponent(ctx.owner)}/${encodeURIComponent(ctx.repo)}/commits/branch/${encodeURIComponent(ctx.branch)}${historyPath}`;
    const folderIcon = fontAwesomeIcon("folder", 512, 512, "M64 480l384 0c35.3 0 64-28.7 64-64l0-224c0-35.3-28.7-64-64-64l-160 0-39.8-53c-12.1-16.1-31.1-26-51.2-26L64 48C28.7 48 0 76.7 0 112L0 416c0 35.3 28.7 64 64 64z");
