  const openfaceJson = async (url) => {
    if (typeof window.fetch === "function") {
      let controller = null;
      try {
        controller = typeof window.AbortController === "function" ? new window.AbortController() : null;
      } catch {
        controller = null;
      }
      const timer = controller ? window.setTimeout(() => controller.abort(), 2500) : null;
      try {
        const response = await window.fetch(url, { credentials: "same-origin", signal: controller?.signal });
        if (!response.ok) return null;
        return response.json();
      } catch {
        return null;
      } finally {
        if (timer) window.clearTimeout(timer);
      }
    }

    return new Promise((resolve) => {
      const xhr = new XMLHttpRequest();
      xhr.open("GET", url, true);
      xhr.withCredentials = true;
      xhr.onreadystatechange = () => {
        if (xhr.readyState !== 4) return;
        if (xhr.status < 200 || xhr.status >= 300) {
          resolve(null);
          return;
        }
        try {
          resolve(JSON.parse(xhr.responseText));
        } catch {
          resolve(null);
        }
      };
      xhr.onerror = () => resolve(null);
      xhr.send();
