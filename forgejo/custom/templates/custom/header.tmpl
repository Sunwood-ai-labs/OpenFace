    return `${(bytes / (1024 * 1024)).toFixed(2).replace(/\.0+$/, "")} MB`;
  };

  const currentTreeContext = () => {
    const match = location.pathname.match(/^\/git\/([^/]+)\/([^/]+)\/src\/branch\/([^/]+)\/?(.*)$/);
    if (!match) return null;
