    const headerRepoMatchRaw = location.pathname.match(/^\/git\/([^/]+)\/([^/]+)/);
    const headerRepoMatch = headerRepoMatchRaw && headerRepoMatchRaw[1] !== "explore" ? headerRepoMatchRaw : null;
