      if (node.parentElement?.closest(".repo-header .repo-buttons")) continue;
      const text = node.nodeValue || "";
      const trimmed = text.trim();
      const replacement = replacements.get(trimmed);
      if (replacement) {
        node.nodeValue = text.replace(trimmed, replacement);
        continue;
      }
      const commitCount = trimmed.match(/^(\d+).*コミット$/);
      if (commitCount) node.nodeValue = text.replace(trimmed, `${commitCount[1]} commits`);
      const openCount = trimmed.match(/^(\d+).*オープン$/);
      if (openCount) node.nodeValue = text.replace(trimmed, `${openCount[1]} Open`);
