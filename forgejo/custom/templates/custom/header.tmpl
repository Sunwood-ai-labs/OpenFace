      ensureHistoryPill(row, ctx);
      if (row && !row.querySelector(".openface-contributors")) {
        const commits = [];
        const commitUrls = [
          `/git/api/v1/repos/${encodeURIComponent(ctx.owner)}/${encodeURIComponent(ctx.repo)}/commits?sha=${encodeURIComponent(ctx.branch)}&limit=100`,
          `/git/api/v1/repos/${encodeURIComponent(ctx.owner)}/${encodeURIComponent(ctx.repo)}/commits?limit=100`,
