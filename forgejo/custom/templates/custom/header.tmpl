<script>
(() => {
  const ready = (fn) => {
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", fn, { once: true });
    } else {
      fn();
    }
  };

  const setText = (el, text) => {
    if (!el) return;
    for (const node of el.childNodes) {
      if (node.nodeType === Node.TEXT_NODE && node.textContent.trim()) {
        if (node.textContent !== text) node.textContent = text;
        return;
      }
    }
    const span = el.querySelector("span.text, span");
    if (span && span.textContent !== text) span.textContent = text;
  };

  const escapeHtml = (value) => String(value)
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#39;");

  const normalizeRelativeTimes = () => {
    const rtf = new Intl.RelativeTimeFormat("en", { numeric: "auto" });
    for (const el of document.querySelectorAll("relative-time[datetime]")) {
      const raw = el.getAttribute("datetime");
      const date = raw ? new Date(raw) : null;
      if (!date || Number.isNaN(date.getTime())) continue;
      const deltaSeconds = Math.round((date.getTime() - Date.now()) / 1000);
      const abs = Math.abs(deltaSeconds);
      let value;
      let unit;
      if (abs < 60) {
        value = deltaSeconds;
        unit = "second";
      } else if (abs < 3600) {
        value = Math.round(deltaSeconds / 60);
        unit = "minute";
      } else if (abs < 86400) {
        value = Math.round(deltaSeconds / 3600);
        unit = "hour";
      } else {
        value = Math.round(deltaSeconds / 86400);
        unit = "day";
      }
      const label = rtf.format(value, unit);
      el.setAttribute("data-openface-time", label);
      if (el.textContent !== label) el.textContent = label;
    }
  };

  const repoKindLabel = () => {
    const topics = Array.from(document.querySelectorAll("#repo-topics .repo-topic, .repo-topic"))
      .map((topic) => topic.textContent.trim().toLowerCase())
      .filter(Boolean);
    if (topics.includes("space")) return "Spaces:";
    if (topics.includes("dataset")) return "Datasets:";
    const repoMatch = location.pathname.match(/^\/git\/([^/]+)\/([^/]+)/);
    const repoName = (repoMatch?.[2] || "").toLowerCase();
    if (repoName.includes("space") || repoName.includes("gradio")) return "Spaces:";
    if (repoName.includes("dataset") || repoName.includes("data")) return "Datasets:";
    return "Models:";
  };

  const labelFromTopics = (topics) => {
    const normalized = topics.map((topic) => String(topic).trim().toLowerCase());
    if (normalized.includes("space")) return "Spaces:";
    if (normalized.includes("dataset")) return "Datasets:";
    return "Models:";
  };

  const repoKindClass = (label) => {
    if (label === "Spaces:") return "space";
    if (label === "Datasets:") return "dataset";
    return "model";
  };

