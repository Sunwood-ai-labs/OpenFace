    const entries = tree
      .filter((entry) => entry?.path && (entry.type === "tree" || entry.type === "blob"))
      .sort((a, b) => {
        if (a.type !== b.type) return a.type === "tree" ? -1 : 1;
        return a.path.localeCompare(b.path);
      })
      .slice(0, 500)
      .map((entry) => {
        const path = String(entry.path).replace(/^\/+|\/+$/g, "");
