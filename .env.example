# ==============================================================================
# OpenFace environment configuration
# Copy this file to `.env` and adjust values before running `docker compose up -d`
# ==============================================================================

# --- Admin bootstrap (used by the `seed` service to create the first Forgejo admin) ---
OPENFACE_ADMIN_USER=openface-admin
OPENFACE_ADMIN_PASSWORD=openface1234
ZAI_AGENT_CONFIG=./maintenance-agent/zai.example.env
ZAI_ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
MAINTENANCE_MODEL=glm-5.2
MAINTENANCE_ALLOWED_OWNER=openface
MAINTENANCE_GOAL_TIMEOUT_SECONDS=3600
MAINTENANCE_MAX_WORKERS=2
OPENFACE_ADMIN_EMAIL=admin@example.com

# --- Forgejo behavior ---
# Closed self-registration is the secure default. Admins invite enterprise users.
DISABLE_REGISTRATION=true

# Private repositories remain inside Forgejo's native ACL by default. Do not
# enable private Spaces unless the runner is protected by an isolated network.
OPENFACE_ALLOW_PRIVATE_SPACES=false

# --- Public URL of the whole platform (gateway entrypoint) ---
OPENFACE_PORT=8090
OPENFACE_HTTPS_PORT=8443
# For access from another LAN device, replace localhost with this PC's LAN IP.
# HTTP on port 8090 is useful for mobile webviews that reject local certificates.
PUBLIC_BASE_URL=https://localhost:8443

# --- PostgreSQL (Forgejo, metrics, and maintenance jobs use separate databases) ---
POSTGRES_USER=openface
POSTGRES_PASSWORD=change-this-postgres-password

# --- Frontend metadata cache (5 minutes by default) ---
README_CACHE_TTL_SECONDS=300

# --- Space capacity (least-recently-used Space is stopped before the next launch) ---
MAX_RUNNING_SPACES=24
